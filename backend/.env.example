# Xpanel Backend - Variáveis de Ambiente
# Normalmente definidas via docker-compose ou Portainer

# Banco de dados PostgreSQL
DATABASE_URL=

# JWT - gere um segredo forte (openssl rand -hex 32)
JWT_SECRET=

# Cookie - gere um segredo forte (openssl rand -hex 32)
COOKIE_SECRET=

# Porta do servidor
PORT=3000

# Node environment
NODE_ENV=production

# Domínio do Xpanel (ex: painel.seudominio.com)
XPANEL_DOMAIN=

# Diretório de sites (container)
XPANEL_SITES_DIR=/home/xpanel/sites

# Diretório de sites (host) - para mapeamento de volumes
XPANEL_HOST_SITES_DIR=/home/xpanel/sites

# Credenciais do admin inicial (troque em produção)
ADMIN_EMAIL=admin@xpanel.local
ADMIN_PASSWORD=xpanel1234
