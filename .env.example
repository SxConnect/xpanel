# Xpanel - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Banco de dados PostgreSQL
POSTGRES_USER= admin@xpanel.local
POSTGRES_PASSWORD= xpanel1234
POSTGRES_DB=xpanel

# JWT - gere um segredo forte: openssl rand -hex 32
JWT_SECRET=

# Cookie - gere um segredo forte: openssl rand -hex 32
COOKIE_SECRET=

# Porta do servidor (padrão: 3000)
PORT=3000

# Domínio do Xpanel (ex: xpanel.seudominio.com)
XPANEL_DOMAIN=

# Node environment
NODE_ENV=production
