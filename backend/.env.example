# Xpanel Backend - Variáveis de Ambiente
# Normalmente definidas via docker-compose.xpanel.yml

# Banco de dados PostgreSQL
DATABASE_URL=

# JWT - gere um segredo forte
JWT_SECRET=

# Cookie - gere um segredo forte
COOKIE_SECRET=

# Porta do servidor
PORT=3000

# Node environment
NODE_ENV=production

# Domínio do Xpanel
XPANEL_DOMAIN=